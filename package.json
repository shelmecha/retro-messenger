{
  "name": "retro-messenger",
  "version": "0.7.1",
  "description": "MSN/Windows-98 styled desktop inbox buddy — a retro messenger that greets you at login and triages your email.",
  "main": "main/main.js",
  "author": "Shelvi Alferez",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:hidden": "electron . --hidden",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "98.css": "^0.1.20",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.shelvi.retromessenger",
    "productName": "Retro Messenger",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main/**",
      "preload/**",
      "renderer/**",
      "mock/**",
      "assets/**",
      "node_modules/**",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "shelmecha",
      "repo": "retro-messenger"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Retro Messenger"
    }
  }
}
